# Environment Variables Example
# Copy this file to .env and update with your actual values
# .env is gitignored and will not be committed

# Application Profile
# Options: dev, prod
SPRING_PROFILES_ACTIVE=dev

# Server Configuration
SERVER_PORT=8080

# Database Configuration (H2 - Development)
DATABASE_URL=jdbc:h2:mem:testdb
DATABASE_DRIVER=org.h2.Driver
DATABASE_USERNAME=sa
DATABASE_PASSWORD=

# Database Configuration (PostgreSQL - Production Example)
# Uncomment and update these when switching to PostgreSQL
# DATABASE_URL=jdbc:postgresql://localhost:5432/yourdb
# DATABASE_DRIVER=org.postgresql.Driver
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your-secure-password

# Database Configuration (MySQL - Production Example)
# Uncomment and update these when switching to MySQL
# DATABASE_URL=jdbc:mysql://localhost:3306/yourdb
# DATABASE_DRIVER=com.mysql.cj.jdbc.Driver
# DATABASE_USERNAME=root
# DATABASE_PASSWORD=your-secure-password

# JPA/Hibernate Configuration
# Options: none, validate, update, create, create-drop
# Use 'validate' or 'none' in production with proper migrations
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# JWT Configuration
# IMPORTANT: Generate a secure 256-bit secret for production
# Generate with: openssl rand -base64 32
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-must-be-at-least-256-bits
# Token expiration in milliseconds
# 900000 = 15 minutes (recommended for production)
# 3600000 = 1 hour
# 86400000 = 24 hours (default for development)
JWT_EXPIRATION=86400000

# H2 Console (Development Only)
# Set to false in production
H2_CONSOLE_ENABLED=true

# Logging Configuration
# Options: TRACE, DEBUG, INFO, WARN, ERROR
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=DEBUG

# Docker Configuration
DOCKER_CONTAINER_NAME=pmd-springboot-api

# Database Container Configuration (for docker-compose)
POSTGRES_DB=mydb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional: External Services
# Add your external service configurations here
# PAYMENT_API_URL=https://api.payment-provider.com
# PAYMENT_API_KEY=your-api-key
# EMAIL_SERVICE_URL=https://api.sendgrid.com
# EMAIL_API_KEY=your-sendgrid-key
